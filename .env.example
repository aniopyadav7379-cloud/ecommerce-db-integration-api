# Copy this file to .env and fill in real values. Never commit the real .env file.

# PostgreSQL connection
POSTGRES_USER=ecom_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=ecommerce_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Full SQLAlchemy database URL (used directly by the app)
DATABASE_URL=postgresql+psycopg2://ecom_user:change_me_strong_password@db:5432/ecommerce_db

# App settings
APP_ENV=development
APP_PORT=8000
